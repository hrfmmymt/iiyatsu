{
  "name": "iiyatsu",
  "version": "2.0.0",
  "description": "hrfmmymt's iiyatsu",
  "keywords": [],
  "author": "hrfmmymt",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "run-s build dev:serve",
    "dev:serve": "wrangler pages dev dist --port 8000",
    "build": "run-s build:content build:css build:pages",
    "build:content": "tsx src/scripts/build-content.ts",
    "build:css": "postcss src/styles/*.css -d public/static/styles/",
    "build:pages": "tsx src/scripts/build-pages.tsx",
    "deploy": "run-s build deploy:publish",
    "deploy:publish": "wrangler pages deploy",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "new-post": "tsx src/scripts/new-post.ts",
    "lint": "biome lint .",
    "format": "biome format . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cloudflare/workers-types": "^4.20241218.0",
    "hono": "^4.6.16",
    "@openameba/spindle-syntax-themes": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/dompurify": "^3.0.5",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^3.9.0",
    "jsdom": "^29.0.0",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.1",
    "npm-run-all2": "^8.0.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "tsx": "^4.19.2",
    "vite": "^7.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.61.1"
  }
}
