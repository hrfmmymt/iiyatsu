{
  "name": "iiyatsu",
  "version": "1.0.0",
  "description": "hrfmmymt's weblog",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "npm-run-all -p server-w css-w",
    "server-w": "nodemon index.js",
    "serve": "firebase serve -p 4444 --only hosting,functions",
    "deploy-fb": "npm-run-all -s get-postslist fb-deploy",
    "deploy": "now alias",
    "test": "npm-run-all -p textlint eslint",
    "img": "node ./utils/img-opt.js",
    "get-postslist": "node ./utils/get-postslist.js",
    "textlint": "textlint ./functions/posts/*",
    "tsc": "tsc --project tsconfig.json",
    "tsc-w": "tsc --watch",
    "eslint": "eslint .",
    "build-sw": "node ./utils/build-sw.js"
  },
  "author": "hrfmmymt",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.9",
    "@types/marked": "^1.2.1",
    "@types/mustache": "^4.1.0",
    "@types/mz": "^2.7.3",
    "@types/node": "^14.14.19",
    "babel-eslint": "^10.1.0",
    "eslint": "^7.17.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-plugin-prettier": "^3.3.0",
    "express": "^4.17.1",
    "glob": "^7.1.6",
    "helmet": "^4.3.1",
    "highlight.js": "^10.5.0",
    "imagemin": "^7.0.1",
    "imagemin-webp": "^6.0.0",
    "jimp": "^0.2.28",
    "marked": "^1.2.7",
    "meta-marked": "^0.5.0",
    "mustache": "^4.1.0",
    "mz": "^2.7.0",
    "nodemon": "^2.0.6",
    "now": "^21.0.1",
    "npm-run-all": "^4.1.5",
    "textlint": "^11.7.7",
    "textlint-filter-rule-comments": "^1.2.2",
    "textlint-filter-rule-whitelist": "^2.0.0",
    "textlint-rule-max-ten": "^2.0.4",
    "textlint-rule-no-mix-dearu-desumasu": "^4.0.1",
    "textlint-rule-spellcheck-tech-word": "^5.0.0",
    "typescript": "^4.1.3",
    "workbox-build": "^6.0.2"
  }
}
