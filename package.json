{
  "name": "iiyatsu",
  "version": "1.0.0",
  "description": "hrfmmymt's weblog",
  "main": "index.js",
  "scripts": {
    "tslint": "tslint --project tsconfig.json",
    "tsc": "tsc --project tsconfig.json",
    "tsc-w": "tsc --watch",
    "css": "postcss -c postcss.config.js -o ./partials/custom-style.mustache ./src/styles/custom-style.css",
    "css-w": "postcss -c postcss.config.js -o ./partials/custom-style.mustache ./src/styles/custom-style.css -w",
    "test": "npm-run-all -p textlint eslint",
    "img": "node ./utils/img-opt.js",
    "get-postslist": "node ./utils/get-postslist.js",
    "textlint": "textlint ./posts/*",
    "eslint": "eslint .",
    "start": "node index.js",
    "dev": "npm-run-all -p server-w css-w",
    "server-w": "nodemon index.js",
    "sw": "workbox injectManifest",
    "build": "npm-run-all -s tsc css sw get-postslist",
    "deploy": "now --prod"
  },
  "author": "hrfmmymt",
  "license": "MIT",
  "dependencies": {
    "express": "^4.17.1",
    "glob": "^7.1.6",
    "helmet": "^3.22.0",
    "highlight.js": "^10.0.2",
    "marked": "^1.0.0",
    "meta-marked": "^0.4.2",
    "mustache": "^4.0.1",
    "mz": "^2.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.6",
    "@types/helmet": "^0.0.46",
    "@types/highlight.js": "^9.12.3",
    "@types/marked": "^0.7.4",
    "@types/mustache": "^4.0.1",
    "@types/mz": "^2.7.0",
    "@types/node": "^13.13.5",
    "autoprefixer": "^9.7.6",
    "babel-eslint": "^10.1.0",
    "cssnano": "^4.1.10",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.3",
    "imagemin": "^7.0.1",
    "imagemin-webp": "^5.1.0",
    "jimp": "0.2.28",
    "nodemon": "^2.0.3",
    "now": "^19.0.0",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^7.1.1",
    "prettier": "^2.0.5",
    "textlint": "^11.6.3",
    "textlint-filter-rule-comments": "^1.2.2",
    "textlint-filter-rule-whitelist": "^2.0.0",
    "textlint-rule-max-ten": "^2.0.3",
    "textlint-rule-no-mix-dearu-desumasu": "^4.0.1",
    "textlint-rule-spellcheck-tech-word": "^5.0.0",
    "tslint": "^6.1.2",
    "typescript": "^3.8.3",
    "workbox-cli": "^3.4.1"
  }
}
