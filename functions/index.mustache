<!DOCTYPE html>
<html amp lang="ja" prefix="og: http://ogp.me/ns#">
  <head>
  {{> meta}}
  </head>
  <body>
    <div class="wrapper">
      {{> header}}
      {{> profile}}
      {{> posts}}
      {{> top}}

      <amp-web-push-widget visibility="unsubscribed" layout="fixed" width="210" height="42">
        <button type="button" class="subscribe" on="tap:amp-web-push.subscribe">プッシュ通知を購読する</button>
      </amp-web-push-widget>

      <amp-web-push-widget visibility="subscribed" layout="fixed" width="210" height="42">
        <button type="button" class="unsubscribe" on="tap:amp-web-push.unsubscribe">プッシュ通知の購読を解除する</button>
      </amp-web-push-widget>

      <amp-web-push-widget visibility="blocked" layout="fixed" width="210" height="42">
        <p><strong>ブラウザの通知機能がブロックされています。購読する場合は通知機能を許可してください。</strong></p>
      </amp-web-push-widget>

      {{> footer}}
    </div>
    <amp-install-serviceworker
      src="/sw.js"
      data-iframe-src="/install-serviceworker.html"
      layout="nodisplay">
    </amp-install-serviceworker>

    <!-- AMP Web Push Extension Configuration -->
    <amp-web-push
      id="amp-web-push"
      layout="nodisplay"
      helper-iframe-url="https://iiyatsu.hrfmmymt.com/helper-iframe.html"
      permission-dialog-url="https://iiyatsu.hrfmmymt.com/permission-dialog.html"
      service-worker-url="https://iiyatsu.hrfmmymt.com/sw.js"
    ></amp-web-push>

    <amp-analytics type="googleanalytics">
      <script type="application/json">
      {
        "vars": {
          "account": "UA-122819743-1"
        },
        "triggers": {
          "trackPageview": {
            "on": "visible",
            "request": "pageview"
          }
        }
      }
      </script>
    </amp-analytics>
  </body>
</html>
