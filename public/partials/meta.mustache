{{#head}}
  <!-- Global site tag (gtag.js) - Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=UA-122819743-1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'UA-122819743-1');
  </script>
  <meta charset="utf-8">
  <meta name="author" content="hrfmmymt">
  <meta name="copyright" content="Copyright(c)hrfmmymt. {{year}} All Rights Reserved.">
  <meta name="description" content="{{description}}">
  <meta name="format-detection" content="telephone=no,address=no,email=no">
  <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1">
  <meta name="theme-color" content="#fff">
  <meta property="og:description" content="{{description}}">
  <meta property="og:title" content="{{title}}">
  <meta property="og:url" content="{{{url}}}">
  <meta property="og:image" content="{{{ogImg}}}">
  <meta property="og:type" content="{{{ogType}}}">
  <meta property="og:locale" content="ja_JP">
  <meta name="twitter:title" content="{{title}}">
  <meta name="twitter:description" content="{{description}}">
  <meta name="twitter:image" content="{{{twitterImg}}}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:site" content="{{{twitterAccount}}}">
  <meta name="twitter:creator" content="{{{twitterAccount}}}">
  <title>{{title}}</title>
  <link rel="canonical" href="{{{url}}}">
  <link rel="shortcut icon" type="image/x-icon" href="/img/icons/favicon.ico">
  <link rel="apple-touch-icon" type="image/png" href="/img/icons/icon.png">
  <link rel="image_src" href="/img/icons/icon.png">
  <link rel="icon" type="image/png" href="/img/icons/icon.png">
  <link rel="manifest" href="/sw/manifest.json">
  <link rel="preconnect" href="https://fonts.googleapis.com/" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Open+Sans">
  <style>{{> custom-style }}</style>
  <script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{{url}}}"
    },
    "headline": "{{title}}",
    "datePublished": "{{{publishedTime}}}",
    "dateModified": "{{{modifiedTime}}}",
    "author": {
      "@type": "Person",
      "name": "hrfmmymt"
    },
    "publisher": {
      "@type": "Organization",
      "name": "iiyatsu - hrfmmymt&#39;s weblog",
      "logo": {
        "@type": "ImageObject",
        "url": "{{{ogImg}}}",
        "width": "512",
        "height": "512"
      }
    },
    "image": {
      "@type": "ImageObject",
      "url": "{{{ogImg}}}",
      "width": "512",
      "height": "512"
    }
  }
  </script>
{{/head}}
